install.packages("brms")
# Load packages
library(brms)
library(dplyr)
# Set seed for reproducibility
set.seed(123)
# Simulate data: 3 groups with different means
n_per_group <- 30
group <- rep(c("A", "B", "C"), each = n_per_group)
# True means for each group
mu <- c(A = 10, B = 13, C = 9)
# Simulate outcome with normal noise
outcome <- rnorm(n_per_group * 3, mean = mu[group], sd = 2)
# Put data in a data frame
sim_data <- data.frame(
outcome = outcome,
group = factor(group)
)
# Quick check
head(sim_data)
table(sim_data$group)
# Define formula
formula <- bf(outcome ~ group)
# Define informed priors
priors <- c(
prior(normal(10, 2), class = "Intercept"),          # Prior for group A mean
prior(normal(3, 1), class = "b", coef = "groupB"),  # Prior for difference B vs A
prior(normal(-1, 0.5), class = "b", coef = "groupC") # Prior for difference C vs A
)
# Fit the model
fit <- brm(
formula = formula,
data = sim_data,
prior = priors,
iter = 4000,
warmup = 1000,
chains = 4,
seed = 123
)
# See summary
summary(fit)
