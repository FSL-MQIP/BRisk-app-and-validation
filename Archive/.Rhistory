library(BayesFactor)
# Example means and SDs for 20 groups from preliminary data
prelim_means <- c(2.5, 2.8, 3.1, 2.9, 3.3, 2.7, 3.0, 2.6, 3.4, 2.8,
3.2, 2.9, 3.5, 2.7, 3.1, 2.9, 3.3, 2.8, 3.0, 2.6)
prelim_sds <- c(0.5, 0.6, 0.55, 0.6, 0.65, 0.5, 0.55, 0.5, 0.7, 0.6,
0.6, 0.55, 0.7, 0.5, 0.55, 0.6, 0.65, 0.55, 0.5, 0.5)
# Number of groups in the main study
k <- 139
# Repeat preliminary means and SDs to length k = 139 groups
group_means <- rep(prelim_means, length.out = k)
group_sds <- rep(prelim_sds, length.out = k)
simulate_bf_anova_unequal_sd <- function(group_means, group_sds, n_per_group, reps = 500, bf_threshold = 3) {
k <- length(group_means)
bfs <- numeric(reps)
for (i in 1:reps) {
group <- factor(rep(1:k, each = n_per_group))
y <- unlist(mapply(function(mu, sd) rnorm(n_per_group, mean = mu, sd = sd),
group_means, group_sds))
df <- data.frame(y = y, group = group)
bf_result <- anovaBF(y ~ group, data = df, progress = FALSE)
bfs[i] <- as.numeric(bf_result[1])
}
prop_H1 <- mean(bfs > bf_threshold)
prop_H0 <- mean(bfs < 1 / bf_threshold)
prop_inconclusive <- 1 - prop_H1 - prop_H0
cat("Sample size per group:", n_per_group, "\n")
cat(sprintf("  BF > %.1f (Support for H1): %.1f%%\n", bf_threshold, 100 * prop_H1))
cat(sprintf("  BF < 1/%.1f (Support for H0): %.1f%%\n", bf_threshold, 100 * prop_H0))
cat(sprintf("  Inconclusive (%.2f < BF < %.1f): %.1f%%\n\n", 1 / bf_threshold, bf_threshold, 100 * prop_inconclusive))
return(list(bfs = bfs))
}
# Test sample sizes per group and print results
for (n in c(3, 5, 7, 10, 15)) {
set.seed(123)
simulate_bf_anova_unequal_sd(group_means, group_sds, n_per_group = n, reps = 500, bf_threshold = 3)
}
str(df)
