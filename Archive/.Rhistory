# Load necessary packages
library(BayesFactor)
library(tidyr)
library(dplyr)
# Set seed for reproducibility
set.seed(123)
# Define group means and SDs (20 groups)
group_means <- seq(2, 4, length.out = 20)  # example means from 2 to 4
group_sds <- seq(0.5, 1.5, length.out = 20)  # example SDs from 0.5 to 1.5
n_per_group <- 6  # sample size per group
# Simulate data for each group
sim_list <- lapply(1:20, function(i) {
rnorm(n_per_group, mean = group_means[i], sd = group_sds[i])
})
# Combine into a data frame in wide format
sim_data_wide <- as.data.frame(do.call(cbind, sim_list))
colnames(sim_data_wide) <- paste0("y.", 1:20)
# Add row ids (optional)
sim_data_wide$id <- 1:n_per_group
# Convert from wide to long format
sim_data_long <- sim_data_wide %>%
pivot_longer(
cols = starts_with("y."),
names_to = "group",
values_to = "y"
) %>%
mutate(
group = factor(group)
)
# Run Bayesian ANOVA
bf_result <- anovaBF(y ~ group, data = sim_data_long, progress = FALSE)
# Print the result
print(bf_result)
library(BayesFactor)
# Example parameters
group_means <- c(2.5, 2.7, 2.8, 3.0, 3.2)
group_sds <- c(0.5, 0.6, 0.4, 0.7, 0.5)
bf_threshold <- 3       # Bayes factor threshold for detection
target_power <- 0.8     # Desired power level
reps <- 500             # Simulations per sample size
min_n <- 5              # Starting sample size per group
max_n <- 100            # Maximum sample size to try
estimate_power <- function(n_per_group) {
success <- 0
for (i in 1:reps) {
sim_data <- data.frame(y = numeric(0), group = factor())
for (g in 1:length(group_means)) {
group_data <- rnorm(n_per_group, mean = group_means[g], sd = group_sds[g])
sim_data <- rbind(sim_data, data.frame(y = group_data, group = factor(g)))
}
bf_result <- anovaBF(y ~ group, data = sim_data, progress = FALSE)
bf_value <- as.numeric(bf_result[1])
if (bf_value >= bf_threshold) {
success <- success + 1
}
}
return(success / reps)
}
# Search for minimum n_per_group
for (n in min_n:max_n) {
power_est <- estimate_power(n)
cat("Sample size:", n, "Estimated power:", round(power_est, 3), "\n")
if (power_est >= target_power) {
cat("Minimum sample size per group to reach power", target_power, "is", n, "\n")
break
}
}
library(BayesFactor)
# Example inputs (replace with your real group means and SDs)
group_means <- c(2.5, 2.7, 2.8, 3.0, 3.2)  # for example, 5 groups here
group_sds <- c(0.5, 0.6, 0.4, 0.7, 0.5)
n_per_group <- 10     # sample size per group
bf_threshold <- 3     # Bayes factor threshold to count as success
reps <- 500           # number of simulations
success <- 0          # counter for successful detections
for (i in 1:reps) {
sim_data <- data.frame(y = numeric(0), group = factor())
# Simulate data for each group
for (g in 1:length(group_means)) {
group_data <- rnorm(n_per_group, mean = group_means[g], sd = group_sds[g])
sim_data <- rbind(sim_data, data.frame(y = group_data, group = factor(g)))
}
# Run Bayesian ANOVA
bf_result <- anovaBF(y ~ group, data = sim_data, progress = FALSE)
# Extract Bayes factor for the model with group effect
bf_value <- as.numeric(bf_result[1])
# Check if Bayes factor meets threshold
if (bf_value >= bf_threshold) {
success <- success + 1
}
}
