ref_df = read.csv("Cytotoxicity_data.csv")
Group_VI_df = subset(ref_df, panC_Group == "Group_VI")
ref_ecdf <- ecdf(ref_df$Average_Cell_Viability_F)
Group_VI_df$percentile_ref <- ref_ecdf(Group_VI_df$Average_Cell_Viability_F) * 100
Group_VI_pc = median(Group_VI_df$percentile_ref)
Group_VI_pc
